{},
{}
]
},
"sentences": [
{
"id": 1,
"text": {
"en": "Sam s'arręte devant le tableau."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 2,
"text": {
"en": "Trois victimes. Toutes retrouvées avec la męme pičce mécanique manquante dans le crâne. Une petite bobine de cuivre, encastrée dans le cortex."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 3,
"text": {
"en": " Qui ferait une chose pareille ? Et pourquoi ?"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 4,
"text": {
"en": "« Comme si le tueur… cherchait quelque chose qu'il a perdu."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"speaker": "O_HERO"
}
],
"speaker": "O_HERO"
