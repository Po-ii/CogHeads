},
"dialogs": [
{
"sid": 24,
"uid": "D_BED",
"content": {
"sentence": {
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 1,
"text": {
"en": "Encore une nuit blanche. \r\nLes ręves reviennent… toujours les męmes images. \r\nLa pluie. Le verre brisé. Cette route."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 2,
"text": {
"en": "Moe dit que je devrais consulter un médecin."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 3,
"text": {
"en": "Il s'inquičte trop."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"speaker": "O_HERO"
}
],
"speaker": "O_HERO"
}
],
"speaker": "O_HERO"
}
]
},
"nextID": 4
}
},
{
"sid": 36,
"uid": "D_TELEPHONE",
"content": {
"sentence": {
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 1,
"text": {
"en": "Sam approche le téléphone et y reponds."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 2,
"text": {
"en": "Moe : Sam ! Enfin. Je t'appelle depuis une heure. Il y a un nouveau meurtre. Rue des Ateliers."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 3,
"text": {
"en": "Sam : Je suis lŕ, Moe. J'arrive."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 4,
"text": {
"en": "Moe : Tu vas bien ? Ta voix est bizarre."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 5,
"text": {
"en": "Sam : Je vais bien. J'arrive."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 6,
"text": {
"en": "Il raccroche."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 7,
"text": {
"en": "Sam : Encore un."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"speaker": "O_HERO"
}
],
"speaker": "O_NARRATOR"
}
],
"speaker": "O_HERO"
}
],
"speaker": "O_MOE"
}
],
"speaker": "O_HERO"
}
],
"speaker": "O_MOE"
}
],
"speaker": "O_NARRATOR"
}
]
},
"nextID": 8
}
},
{
"sid": 37,
"uid": "D_PROOF",
"content": {
"sentence": {
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 1,
"text": {
"en": "Sam s'arręte devant le tableau."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 2,
"text": {
"en": "Trois victimes.\r\nToutes retrouvées avec la męme pičce mécanique manquante dans le crâne. \r\nUne petite bobine de cuivre, encastrée dans le cortex."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 3,
"text": {
"en": " Qui ferait une chose pareille ? Et pourquoi ?"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 4,
"text": {
"en": "Comme si le tueur… cherchait quelque chose qu'il a perdu."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"speaker": "O_HERO"
}
],
"speaker": "O_HERO"
}
],
"speaker": "O_HERO"
}
],
"speaker": "O_NARRATOR"
}
]
},
"nextID": 5
}
},
{
"sid": 40,
"uid": "D_JOURNAL",
"content": {
"sentence": {
"sentences": [
{
"id": 1,
"text": {
"en": "Quel entrée souhaites-tu consulter ?"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 2,
"choice": true,
"text": {
"en": "- 12 mars"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 4,
"voice": {
"en": [
{},
{},
{},
{}
]
},
"text": {
"en": "12 mars — L'accident date de huit mois maintenant. \r\nLe docteur parle de \"lacunes mnésiques\". Des trous. Des blancs. \r\nComme si quelqu'un avait arraché des pages entičres de ma mémoire."
},
"speaker": "O_NARRATOR"
}
],
"do_not_say": true
},
{
"id": 3,
"choice": true,
"sentences": [
{
"id": 5,
"voice": {
"en": [
{},
{},
{},
{}
]
},
"text": {
"en": "Il y a des entrées que je ne reconnais pas. \r\nMon écriture, mais pas mes mots. \r\nComme si quelqu'un d'autre avait écrit ŕ ma place pendant mes absences."
},
"speaker": "O_HERO"
}
],
"text": {
"en": "- ????"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"do_not_say": true
}
],
"speaker": "O_NARRATOR"
}
],
"voice": {
"en": [
{},
{},
{},
{}
]
}
},
"nextID": 6
}
},
{
"sid": 41,
"uid": "D_OUTSIDE",
"content": {
"sentence": {
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 1,
"text": {
"en": "Assez perdu de temps. Rue des Ateliers.\r\n\r\n"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 2,
"text": {
"en": "Il saisit son badge oů est ecrit :\r\n       \"S. KIZO-PHRENEL\""
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 3,
"text": {
"en": "On va l'avoir, ce tueur."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"speaker": "O_HERO"
}
],
"speaker": "O_NARRATOR"
}
],
"speaker": "O_HERO"
}
]
},
"nextID": 4
}
},
{
"sid": 44,
"uid": "D_EXIT",
"content": {
"sentence": {
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 1,
"text": {
"en": "Oů voullez-vous aller ?"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 2,
"choice": true,
"text": {
"en": "- Les alentours"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"do_not_say": true
},
{
"id": 3,
"choice": true,
"text": {
"en": "- La maison"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"do_not_say": true
},
{
"id": 4,
"choice": true,
"sentences": [
{
"id": 5,
"text": {
"en": "Je vais rester encore un peu.\r\nil reste peut-ętre d'autre indices."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"speaker": "O_HERO"
}
],
"text": {
"en": "- Retour"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"do_not_say": true
}
],
"speaker": "O_NARRATOR"
}
]
},
"nextID": 6
}
},
{
"sid": 45,
"uid": "D_SCIENTIST",
"content": {
"sentence": {
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 1,
"text": {
"en": "Alors, qui est la victime ?"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 2,
"text": {
"en": "Vik Tim."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 3,
"text": {
"en": "il pointe vers la victime."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 4,
"text": {
"en": "Hmmm... et t'as son identité ?"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 5,
"text": {
"en": "C'est ce que je viens de vous dire. Vik Tim."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 6,
"text": {
"en": "...Ah."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 7,
"text": {
"en": "C'est triste quand męme."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 8,
"text": {
"en": "La victime ou le prénom ?"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 10,
"text": {
"en": "Les deux, chef."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 11,
"text": {
"en": "Si vous avez fini... j'ai aussi les témoins."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 12,
"text": {
"en": "Vas-y."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 13,
"text": {
"en": "Un certain Jean Cérien."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 14,
"text": {
"en": "Jean Cérien a rien vu ?"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 15,
"text": {
"en": "Si, mais il dit que c'était quelqu'un de normal."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 16,
"text": {
"en": "Normal comment ?"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 17,
"text": {
"en": "Normal, quoi. Jean Cérien, il voit rien d'anormal."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 18,
"text": {
"en": "(soupir) Et les autres ?"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 19,
"text": {
"en": "Joachim De La Vega, dit \"le Z\"."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 20,
"text": {
"en": "Dit \"le Z\" ?"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 21,
"text": {
"en": "Il a pas voulu expliquer."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"sentences": [
{
"id": 22,
"text": {
"en": "(soupir) Bien sűr que non."
},
"voice": {
